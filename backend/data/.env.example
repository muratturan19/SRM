# Kolektif360 CRM — Backend Environment Variables
# Copy this file to data/.env and fill in your values.

# ── PostgreSQL ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/kolektif360_crm
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:your_password@localhost:5432/kolektif360_crm

# ── LLM API Keys ─────────────────────────────────────────────────
# Claude Sonnet 4.6 (primary card scanner)
ANTHROPIC_API_KEY=sk-ant-...

# GPT-5.5 via Responses API (fallback card scanner)
OPENAI_API_KEY=sk-...

# Primary scan provider: "claude" or "gpt"
SCAN_PROVIDER=claude

# ── File storage ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
